{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A luxury transition project (Next Chapter, Archives, etc.)",
      "type": "object",
      "properties": {
        "clientName": { "type": "string" },
        "serviceType": { "type": "string", "enum": ["Home Organization", "Legacy Archives", "Curated Resale", "Transition Support"] },
        "status": { "type": "string", "enum": ["Inquiry", "Proposal", "In Progress", "Completed"] },
        "location": { "type": "string" },
        "totalHours": { "type": "number" },
        "revenue": { "type": "number" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientName", "serviceType", "status"]
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "An item for the Curated Resale bridge",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "estimatedValue": { "type": "number" },
        "status": { "type": "string", "enum": ["Sourced", "Authenticated", "Listed", "Sold"] },
        "buyerNotes": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "status"]
    },
    "BrandContent": {
      "title": "Brand Content",
      "description": "PR drafts, ads, and website copy",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["PR", "Ad Copy", "Website Text", "Social"] },
        "body": { "type": "string" },
        "targetAudience": { "type": "string" },
        "isApproved": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "body"]
    }
  },
  "firestore": {
    "projects": {
      "schema": "Project",
      "description": "Master project pipeline"
    },
    "inventory": {
      "schema": "InventoryItem",
      "description": "Resale bridge manifests"
    },
    "content": {
      "schema": "BrandContent",
      "description": "Brand engine output"
    }
  }
}
